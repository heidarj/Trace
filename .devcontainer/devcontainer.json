// .devcontainer/devcontainer.json
{
  "name": "aspire-dotnet-react",
  "image": "mcr.microsoft.com/devcontainers/dotnet:dev-10.0-noble",

  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "lts"
    }
  },

  "onCreateCommand": "bash .devcontainer/on-create.sh",
  "updateContentCommand": "bash .devcontainer/update-content.sh",
  "postStartCommand": "bash .devcontainer/post-start.sh",

  "remoteEnv": {
    "ASPNETCORE_ENVIRONMENT": "Development",
    "DOTNET_ENVIRONMENT": "Development",
    "DOTNET_NOLOGO": "1",
    "DOTNET_CLI_TELEMETRY_OPTOUT": "1"
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "github.copilot",
        "github.copilot-chat",
        "ms-dotnettools.csdevkit",
        "ms-dotnettools.csharp",
        "ms-dotnet.aspire-vscode",
        "ms-vscode.vscode-typescript-next"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "files.trimTrailingWhitespace": true,
        "terminal.integrated.defaultProfile.linux": "bash",
        "js/ts.tsdk.path": "web/app/node_modules/typescript/lib"
      }
    }
  },

  "forwardPorts": [18888, 5173, 5000, 5001],

  "portsAttributes": {
    "18888": {
      "label": "Aspire Dashboard",
      "onAutoForward": "openPreview",
      "visibility": "private"
    },
    "5173": {
      "label": "React Frontend",
      "onAutoForward": "openPreview",
      "visibility": "private"
    },
    "5000": {
      "label": "API HTTP",
      "onAutoForward": "silent",
      "visibility": "private"
    },
    "5001": {
      "label": "API HTTPS",
      "onAutoForward": "silent",
      "visibility": "private"
    }
  },

  "secrets": {
    "ConnectionStrings__cosmos": {
      "description": "Recommended for Codespaces. Existing Azure Cosmos DB account connection string or account endpoint for AddConnectionString(\"cosmos\")."
    },
    "UseContainerEmulators": {
      "description": "Optional. Set to true only when you have explicitly enabled a local container runtime and want the Cosmos emulator path."
    },
    "AzureAd__TenantId": {
      "description": "Optional. Entra tenant ID for local dev auth."
    },
    "AzureAd__ClientId": {
      "description": "Optional. Entra client ID for local dev auth."
    },
    "AzureAd__ClientSecret": {
      "description": "Optional. Entra client secret for local dev auth."
    }
  }
}